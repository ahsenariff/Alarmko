<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="72dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Заглавие -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="16dp"/>

        <!-- Секция Камера мисия -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/camera_mission_settings"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/camera_mission_hint"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp"/>

        <!-- Кухня -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_kitchen"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchGlass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_glass"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFridge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_fridge"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPlate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_plate"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchWaterBottle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_water_bottle"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchCoffeeCup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_coffee_cup"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Баня -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_bathroom"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchToothbrush"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_toothbrush"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSoap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_soap"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTowel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_towel"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchMirror"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_mirror"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Здраве -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_health"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_pill"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchThermometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_thermometer"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchVitamins"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_vitamins"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Работно място -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_workspace"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotebook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_notebook"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchPen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_pen"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchKeyboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_keyboard"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchMouse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_mouse"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Всекидневна -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_living_room"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchKeys"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_keys"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_book"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchRemote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_remote"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchWindow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/object_window"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDarkTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_dark"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>