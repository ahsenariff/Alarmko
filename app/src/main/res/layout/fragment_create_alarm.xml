<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar с бутон назад -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="@string/create_alarm_title"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="@string/back"/>

    <!-- Останалото съдържание -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TimePicker -->
        <TimePicker
            android:id="@+id/timePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="clock"/>

        <!-- Дни за повторение -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/repeat_days"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/monday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tuesday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wednesday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipThu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/thursday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/friday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saturday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sunday"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Описание на задача -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/task_description"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTaskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="2"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Избор на мисия -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_mission"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupMissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMissionMath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mission_math"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMissionShake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mission_shake"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMissionQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mission_qr"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMissionPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mission_photo"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMissionSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mission_steps"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Известие преди -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notify_before"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupNotify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNotifyNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_notification"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNotify5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notify_5"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNotify10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notify_10"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNotify15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notify_15"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNotify30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notify_30"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- Бутон Запази -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_alarm"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            app:backgroundTint="?attr/colorPrimary"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

</LinearLayout>